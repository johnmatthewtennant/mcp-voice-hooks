{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); curl -s -X POST \"http://localhost:${MCP_VOICE_HOOKS_PORT:-5111}/api/hooks/stop\" -H 'Content-Type: application/json' -d \"$INPUT\" || echo '{}'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "_voice-hooks__speak$",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); curl -s -X POST \"http://localhost:${MCP_VOICE_HOOKS_PORT:-5111}/api/hooks/pre-speak\" -H 'Content-Type: application/json' -d \"$INPUT\" || echo '{}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(?!.*_voice-hooks__)",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); curl -s -X POST \"http://localhost:${MCP_VOICE_HOOKS_PORT:-5111}/api/hooks/post-tool\" -H 'Content-Type: application/json' -d \"$INPUT\" || echo '{}'"
          }
        ]
      }
    ]
  }
}